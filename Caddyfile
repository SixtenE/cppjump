{
	# Railway terminates TLS in front of the container, so we serve plain
	# HTTP inside and let Caddy just route.
	admin off
	auto_https off
}

:{$PORT:8080} {
	encode gzip zstd

	# WebSocket relay: Caddy upgrades and proxies to the C++ server.
	handle /ws {
		reverse_proxy 127.0.0.1:8090
	}

	# Static web client (with SPA fallback to index.html).
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
